# Consolidated Gitignore for Golf Project

# Dependencies
node_modules/
jspm_packages/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Build and Production
dist/
build/
.next/
out/
.nuxt
.serverless/
.fusebox/
.dynamodb/
.turbo
*.tgz

# Environment Variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*
.node_repl_history

# Testing
coverage/
*.lcov
.nyc_output

# Editor and OS
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.tern-port
*.tsbuildinfo

# Tool Caches
.npm
.eslintcache
.stylelintcache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/
.cache
.parcel-cache
.vercel

# Misc
next-env.d.ts
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json
pids
*.pid
*.seed
*.pid.lock
lib-cov
.grunt
bower_components
.lock-wscript
.yarn-integrity
